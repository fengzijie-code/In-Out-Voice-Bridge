<Application x:Class="InOutVoiceBridge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#1DB954</Color>
            <Color x:Key="PrimaryHoverColor">#25D366</Color>
            <Color x:Key="BackgroundColor">#11111B</Color>
            <Color x:Key="BackgroundAccentColor">#1E1E2E</Color>
            <Color x:Key="SurfaceColor">#2A2A3C</Color>
            <Color x:Key="CardColor">#252538</Color>
            <Color x:Key="CardBorderColor">#3B3B55</Color>
            <Color x:Key="TextColor">#CDD6F4</Color>
            <Color x:Key="SubtextColor">#A6ADC8</Color>
            <Color x:Key="ErrorColor">#F38BA8</Color>
            <Color x:Key="WarningColor">#FAB387</Color>
            <Color x:Key="RenderColor">#89B4FA</Color>
            <Color x:Key="InputBorderColor">#4B4B68</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHoverColor}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="BackgroundAccentBrush" Color="{StaticResource BackgroundAccentColor}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
            <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
            <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
            <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
            <SolidColorBrush x:Key="RenderBrush" Color="{StaticResource RenderColor}"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
            <SolidColorBrush x:Key="HoverBrush" Color="#20FFFFFF"/>
            <SolidColorBrush x:Key="PressedBrush" Color="#14000000"/>
            <SolidColorBrush x:Key="SelectedBrush" Color="#3D1DB954"/>
            <SolidColorBrush x:Key="MeterTrackBrush" Color="#20FFFFFF"/>
            <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#30FAB387"/>
            <SolidColorBrush x:Key="ErrorBackgroundBrush" Color="#30F38BA8"/>

            <LinearGradientBrush x:Key="WindowBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#11111B" Offset="0"/>
                <GradientStop Color="#1E1E2E" Offset="0.55"/>
                <GradientStop Color="#18251F" Offset="1"/>
            </LinearGradientBrush>

            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                <Setter Property="Padding" Value="8,5"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
