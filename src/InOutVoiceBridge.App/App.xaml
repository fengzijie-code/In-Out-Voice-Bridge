<Application x:Class="InOutVoiceBridge.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryColor">#1DB954</Color>
            <Color x:Key="BackgroundColor">#1E1E2E</Color>
            <Color x:Key="SurfaceColor">#2A2A3C</Color>
            <Color x:Key="TextColor">#CDD6F4</Color>
            <Color x:Key="SubtextColor">#A6ADC8</Color>
            <Color x:Key="ErrorColor">#F38BA8</Color>
            <Color x:Key="WarningColor">#FAB387</Color>

            <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
            <SolidColorBrush x:Key="SubtextBrush" Color="{StaticResource SubtextColor}"/>
            <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
            <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
